{
  "name": "fang",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fang": "src/cli.ts"
  },
  "main": "src/index.ts",
  "description": "Every CLI agent is an island. Fang builds the bridge. A2A-compliant server for any CLI coding agent.",
  "license": "MIT",
  "keywords": [
    "a2a",
    "agent",
    "cli",
    "pi",
    "aider",
    "claude-code",
    "codex",
    "gemini",
    "coding-agent",
    "fang"
  ],
  "scripts": {
    "start": "node --experimental-strip-types src/cli.ts",
    "dev": "node --experimental-strip-types src/cli.ts",
    "fang": "node ./packages/cli/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "commander": "^13.1.0",
    "express": "^4.22.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@fangai/adapter-aider": "workspace:*",
    "@fangai/adapter-claude": "workspace:*",
    "@fangai/adapter-codex": "workspace:*",
    "@fangai/adapter-generic": "workspace:*",
    "@fangai/adapter-opencode": "workspace:*",
    "@fangai/pi": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@types/which": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kariemSeiam/fangai.git"
  }
}
