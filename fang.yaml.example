agents:
  pi:
    cli: "pi --mode rpc"
    port: 3001
    timeout: 600

  claude:
    cli: "claude"
    port: 3002
    timeout: 300

  aider:
    cli: "aider"
    port: 3003
    timeout: 300

  codex:
    cli: "codex"
    port: 3004
    timeout: 300

  local:
    cli: "ollama run qwen2.5-coder"
    port: 3005
    timeout: 120
