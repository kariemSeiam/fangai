FROM node:20-slim

# Install Fang CLI
RUN npm install -g @fangai/cli

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Create non-root user
RUN useradd -m -s /bin/bash a2a
USER a2a
WORKDIR /home/a2a/project

EXPOSE 3003

# Start Ollama, pull model, then wrap
CMD sh -c "\
  ollama serve & \
  sleep 5 && \
  ollama pull qwen2.5-coder:7b && \
  fang wrap 'ollama run qwen2.5-coder:7b' --port 3003 --name local-agent --cost-tier free \
"
