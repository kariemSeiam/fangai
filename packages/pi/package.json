{
  "name": "@fangai/pi",
  "version": "0.1.0",
  "type": "module",
  "description": "Fang bridge for the Pi coding agent (`pi --mode rpc`). Maps Pi's JSONL RPC stream to Fang task updates.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@fangai/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": [
    "fang",
    "fangai",
    "a2a",
    "pi",
    "pi-mono",
    "coding-agent",
    "rpc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kariemSeiam/fangai.git",
    "directory": "packages/pi"
  },
  "publishConfig": {
    "access": "public"
  }
}
