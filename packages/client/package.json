{
  "name": "@fangai/client",
  "version": "0.1.0",
  "description": "Thin A2A client for Fang-wrapped agents (orchestrators, scripts, Pi extensions)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": ["a2a", "fang", "agent", "client", "json-rpc"],
  "repository": {
    "type": "git",
    "url": "https://github.com/kariemSeiam/fangai.git",
    "directory": "fang/packages/client"
  },
  "publishConfig": {
    "access": "public"
  }
}
