{
  "name": "@fangai/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Fang — wrap any CLI coding agent as an A2A server (stdin/stdout bridge).",
  "bin": {
    "fang": "./dist/index.js",
    "a2a-cli": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@fangai/client": "workspace:*",
    "@fangai/core": "workspace:*",
    "commander": "^12.0.0",
    "kill-port": "^2.0.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": [
    "a2a",
    "cli",
    "agent",
    "coding",
    "orchestration",
    "mcp",
    "pi",
    "aider",
    "claude-code",
    "codex",
    "opencode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kariemSeiam/fangai.git",
    "directory": "fang/packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
